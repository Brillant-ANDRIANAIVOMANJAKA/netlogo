<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="false">
  <code><![CDATA[;; ============================================================================
;; SIMULATION SIR — PROPAGATION EPIDEMIQUE (PALUDISME / PESTE) — MADAGASCAR
;; ============================================================================
;; Projet academique - Master
;; Domaine : Systemes Multi-Agents, Epidemiologie, Sante Publique
;; Modele : Diffusion SIR avec vecteurs et corridors de mobilite
;; ============================================================================

breed [ humans human ]   ;; Population humaine
breed [ vectors vector ]  ;; Vecteurs (moustiques / puces)
breed [ villages village ] ;; Villages (hubs de population)

humans-own [
  state          ;; "susceptible" "infectious" "recovered" "dead"
  target-village ;; Village de destination
  home-village   ;; Village d'origine
  ticks-sick     ;; Duree de l'infection
]

vectors-own [
  infected?      ;; Porteur du pathogene ?
]

globals [
  total-dead
  total-infected
  total-recovered
  peak-infected
  epidemic-day
]

patches-own [
  is-corridor?   ;; Corridor de mobilite
  base-pcolor
]

;; ============================================================================
;; SETUP
;; ============================================================================

to setup
  clear-all
  set-default-shape humans "person"
  set-default-shape vectors "circle"
  set-default-shape villages "house"

  set total-dead 0
  set total-infected initial-infected
  set total-recovered 0
  set peak-infected 0
  set epidemic-day 0

  setup-environment
  setup-villages
  setup-humans
  setup-vectors
  reset-ticks
end

to setup-environment
  ask patches [
    set is-corridor? false
    set pcolor green + 2
    set base-pcolor pcolor
  ]
  ;; Creer corridors entre villages (axes de transport)
  let v-coords [[-10 -10] [10 10] [-10 10] [10 -10] [0 0]]
  foreach v-coords [ c1 ->
    foreach v-coords [ c2 ->
      if c1 != c2 [
        let x1 item 0 c1
        let y1 item 1 c1
        let x2 item 0 c2
        let y2 item 1 c2
        ask patches [
          if (distancexy x1 y1) + (distancexy x2 y2) < (sqrt ((x1 - x2) ^ 2 + (y1 - y2) ^ 2)) + 0.3 [
            set is-corridor? true
            set pcolor grey
            set base-pcolor grey
          ]
        ]
      ]
    ]
  ]
end

to setup-villages
  create-villages 5 [
    let c item who [[-10 -10] [10 10] [-10 10] [10 -10] [0 0]]
    setxy item 0 c item 1 c
    set color white
    set size 3
  ]
end

to setup-humans
  create-humans initial-human-pop [
    set state "susceptible"
    set home-village one-of villages
    move-to home-village
    set color blue
    set size 1.2
    set ticks-sick 0
    set target-village nobody
  ]
  ask n-of initial-infected humans [
    set state "infectious"
    set color red
  ]
end

to setup-vectors
  create-vectors initial-vector-pop [
    set infected? false
    set color yellow
    setxy random-xcor random-ycor
    set size 0.8
  ]
  ;; Vecteurs initiaux infectes
  ask n-of (initial-vector-pop / 5) vectors [
    set infected? true
    set color orange
  ]
end

;; ============================================================================
;; GO
;; ============================================================================

to go
  if not any? humans with [state = "infectious"] and
     not any? vectors with [infected?] [ stop ]

  ask humans [ human-move ]
  ask vectors [ vector-move ]
  transmit-disease
  ask humans [ check-health ]
  update-statistics
  tick
end

to human-move
  if state = "dead" [ stop ]
  if random 1000 < mobility-frequency [
    set target-village one-of villages
  ]
  ifelse target-village != nobody [
    face target-village
    ifelse [is-corridor?] of patch-here [
      fd 0.3
    ] [
      rt random 20 - 10
      fd 0.15
    ]
    if distance target-village < 1 [ set target-village nobody ]
  ] [
    rt random 40 - 20
    fd 0.05
  ]
end

to vector-move
  rt random 60 - 30
  fd 0.4
  if random 100 < 3 [ hatch 1 ]
  if count vectors > (initial-vector-pop * 2) [
    ask one-of vectors [ die ]
  ]
end

to transmit-disease
  ;; Vecteur sain pique humain infecte
  ask vectors with [ not infected? ] [
    if any? humans-here with [ state = "infectious" ] [
      if random-float 100 < transmission-rate [
        set infected? true
        set color orange
      ]
    ]
  ]
  ;; Vecteur infecte pique humain sain
  ask humans with [ state = "susceptible" ] [
    if any? vectors-here with [ infected? ] [
      if random-float 100 < transmission-rate [
        set state "infectious"
        set color red
        set total-infected total-infected + 1
      ]
    ]
  ]
end

to check-health
  if state = "infectious" [
    set ticks-sick ticks-sick + 1
    if ticks-sick > 50 [
      ifelse random-float 100 < mortality-rate [
        set state "dead"
        set color grey
        set total-dead total-dead + 1
      ] [
        if random-float 100 < recovery-chance [
          set state "recovered"
          set color green
          set total-recovered total-recovered + 1
        ]
      ]
    ]
  ]
end

to update-statistics
  let current-infected count humans with [state = "infectious"]
  if current-infected > peak-infected [
    set peak-infected current-infected
    set epidemic-day ticks
  ]
end

;; ============================================================================
;; REPORTERS
;; ============================================================================

to-report nb-sains
  report count humans with [state = "susceptible"]
end

to-report nb-infectes
  report count humans with [state = "infectious"]
end

to-report nb-gueris
  report count humans with [state = "recovered"]
end

to-report nb-morts
  report total-dead
end

to-report taux-mortalite
  ifelse total-infected > 0 [
    report precision (total-dead / total-infected * 100) 1
  ] [ report 0 ]
end

to-report taux-infection
  ifelse any? humans [
    report precision (count humans with [state = "infectious"] / count humans * 100) 1
  ] [ report 0 ]
end

to-report etat-epidemie
  let n count humans with [state = "infectious"]
  ifelse n = 0 [ report "TERMINEE" ]
  [ ifelse n < 10 [ report "Faible" ]
    [ ifelse n < 50 [ report "Moderee" ]
      [ ifelse n < 100 [ report "Elevee" ]
        [ report "CRITIQUE" ] ] ] ]
end

to export-data-csv
  let filename (word "epidemie_data_" ticks ".csv")
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "tick,sains,infectes,gueris,morts,vecteurs_infectes,taux_infection,taux_mortalite"
  file-print (word ticks ","
    count humans with [state = "susceptible"] ","
    count humans with [state = "infectious"] ","
    count humans with [state = "recovered"] ","
    total-dead ","
    count vectors with [infected?] ","
    taux-infection ","
    taux-mortalite)
  file-close
  user-message (word "Donnees exportees : " filename)
end

;; ============================================================================
;; FIN DU CODE
;; ============================================================================]]></code>
