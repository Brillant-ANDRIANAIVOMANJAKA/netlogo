  <linkShapes>
    <shape name="default" curviness="0.0">
      <lines>
        <line x="-0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
        <line x="0.0" visible="true">
          <dash value="1.0"></dash>
          <dash value="0.0"></dash>
        </line>
        <line x="0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
      </lines>
      <indicator>
        <shape name="link direction" rotatable="true" editableColorIndex="0">
          <line endX="90" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
          <line endX="210" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
        </shape>
      </indicator>
    </shape>
  </linkShapes>
  <previewCommands>setup
repeat 200 [ go ]</previewCommands>
  <experiments>
    <experiment name="exp1_transmission" repetitions="3" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="1000">
      <setup>setup</setup>
      <go>go</go>
      <metrics>
        <metric>count humans with [state = "susceptible"]</metric>
        <metric>count humans with [state = "infectious"]</metric>
        <metric>count humans with [state = "recovered"]</metric>
        <metric>total-dead</metric>
        <metric>taux-infection</metric>
        <metric>taux-mortalite</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="initial-human-pop">
          <value value="100"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="initial-vector-pop">
          <value value="200"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="initial-infected">
          <value value="5"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="transmission-rate" first="5" step="10" last="50"></steppedValueSet>
        <enumeratedValueSet variable="recovery-chance">
          <value value="5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="mortality-rate">
          <value value="2"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="mobility-frequency">
          <value value="10"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
    <experiment name="exp2_mobilite" repetitions="3" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="1000">
      <setup>setup</setup>
      <go>go</go>
      <metrics>
        <metric>count humans with [state = "infectious"]</metric>
        <metric>total-dead</metric>
        <metric>peak-infected</metric>
        <metric>epidemic-day</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="initial-human-pop">
          <value value="100"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="initial-vector-pop">
          <value value="200"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="initial-infected">
          <value value="5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="transmission-rate">
          <value value="15"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="recovery-chance">
          <value value="5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="mortality-rate">
          <value value="2"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="mobility-frequency" first="0" step="20" last="100"></steppedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
