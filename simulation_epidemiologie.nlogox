    <button x="250" actionKey="R" y="10" height="40" disableUntilTicks="false" forever="false" kind="Observer" display="RESET" width="90" sizeVersion="0">clear-all
reset-ticks</button>
    <slider x="10" step="10" y="55" max="500" display="initial-human-pop" height="33" min="10" direction="Horizontal" default="100.0" variable="initial-human-pop" units="humains" width="330" sizeVersion="0"></slider>
    <slider x="10" step="10" y="90" max="1000" display="initial-vector-pop" height="33" min="10" direction="Horizontal" default="200.0" variable="initial-vector-pop" units="vecteurs" width="330" sizeVersion="0"></slider>
    <slider x="10" step="1" y="125" max="20" display="initial-infected" height="33" min="1" direction="Horizontal" default="5.0" variable="initial-infected" units="cas" width="330" sizeVersion="0"></slider>
    <slider x="10" step="1" y="160" max="100" display="transmission-rate" height="33" min="0" direction="Horizontal" default="15.0" variable="transmission-rate" units="%" width="330" sizeVersion="0"></slider>
    <slider x="10" step="1" y="195" max="100" display="recovery-chance" height="33" min="0" direction="Horizontal" default="5.0" variable="recovery-chance" units="%" width="330" sizeVersion="0"></slider>
    <slider x="10" step="1" y="230" max="100" display="mortality-rate" height="33" min="0" direction="Horizontal" default="2.0" variable="mortality-rate" units="%" width="330" sizeVersion="0"></slider>
    <slider x="10" step="1" y="265" max="100" display="mobility-frequency" height="33" min="0" direction="Horizontal" default="10.0" variable="mobility-frequency" units="NIL" width="330" sizeVersion="0"></slider>
    <monitor x="10" precision="0" y="310" height="45" fontSize="11" display="Sains" width="78" sizeVersion="0">nb-sains</monitor>
    <monitor x="93" precision="0" y="310" height="45" fontSize="11" display="Infectes" width="78" sizeVersion="0">nb-infectes</monitor>
    <monitor x="176" precision="0" y="310" height="45" fontSize="11" display="Gueris" width="78" sizeVersion="0">nb-gueris</monitor>
    <monitor x="259" precision="0" y="310" height="45" fontSize="11" display="Morts" width="78" sizeVersion="0">nb-morts</monitor>
    <monitor x="10" precision="1" y="360" height="45" fontSize="11" display="Taux infection (%)" width="160" sizeVersion="0">taux-infection</monitor>
    <monitor x="175" precision="1" y="360" height="45" fontSize="11" display="Taux mortalite (%)" width="162" sizeVersion="0">taux-mortalite</monitor>
    <monitor x="10" precision="0" y="410" height="45" fontSize="11" display="Pic epidemique" width="160" sizeVersion="0">peak-infected</monitor>
    <monitor x="175" precision="0" y="410" height="45" fontSize="11" display="Jour du pic" width="162" sizeVersion="0">epidemic-day</monitor>
    <monitor x="870" precision="17" y="10" height="45" fontSize="11" display="Etat epidemie" width="310" sizeVersion="0">etat-epidemie</monitor>
