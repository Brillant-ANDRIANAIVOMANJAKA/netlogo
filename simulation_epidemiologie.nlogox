    <monitor x="1030" precision="0" y="60" height="45" fontSize="11" display="Total infectes" width="150" sizeVersion="0">total-infected</monitor>
    <plot x="870" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="population" y="115" xMin="0.0" height="180" legend="true" xMax="100.0" yMin="0.0" xAxis="ticks" display="Courbe SIR" width="410" sizeVersion="0">
